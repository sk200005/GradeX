<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/shell-start', { pageTitle }) %>

<section class="hero-panel">
  <div>
    <span class="eyebrow">Reports & Analytics</span>
    <h3>Operational reports plus warehouse concepts</h3>
    <p>
      This page combines practical reporting with STAR SCHEMA and SNOWFLAKE
      SCHEMA concepts using separate MongoDB collections.
    </p>
  </div>
  <div class="hero-actions" style="flex-direction: column; align-items: stretch;">
    <div style="display: flex; gap: 15px;">
      <a class="btn btn-secondary" href="/reports/top-students/pdf">Export Top Students PDF</a>
      <button type="button" class="btn btn-primary" id="syncWarehouseBtn">Sync Warehouse</button>
    </div>
    
    <!-- ETL Progress Container -->
    <div id="etlProgressContainer" style="display: none; margin-top: 20px; background: rgba(0,0,0,0.25); padding: 25px; border-radius: 12px; width: 100%; border: 1px solid rgba(255,255,255,0.05);">
      <h4 style="margin-top: 0; margin-bottom: 25px; color: white; font-weight: 600; font-size: 15px;">ETL Pipeline Status</h4>
      
      <div style="display: flex; justify-content: space-between; position: relative; margin-bottom: 10px; max-width: 500px;">
        <!-- Progress Line -->
        <div style="position: absolute; top: 14px; left: 15px; right: 15px; height: 4px; background: #334155; z-index: 0; border-radius: 2px;"></div>
        <div id="etlProgressBar" style="position: absolute; top: 14px; left: 15px; height: 4px; background: #3b82f6; z-index: 1; border-radius: 2px; width: 0%; transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);"></div>
        
        <!-- Steps -->
        <div class="etl-step" id="etlStep1" style="position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 10px; width: 60px;">
          <div class="etl-circle" style="width: 32px; height: 32px; border-radius: 50%; background: #1e293b; border: 2px solid #334155; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; color: #94a3b8; transition: all 0.3s ease; box-shadow: 0 0 0 4px rgba(0,0,0,0.2);">1</div>
          <span style="font-size: 12px; color: #94a3b8; font-weight: 500;">Extract</span>
        </div>
        
        <div class="etl-step" id="etlStep2" style="position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 10px; width: 60px;">
          <div class="etl-circle" style="width: 32px; height: 32px; border-radius: 50%; background: #1e293b; border: 2px solid #334155; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; color: #94a3b8; transition: all 0.3s ease; box-shadow: 0 0 0 4px rgba(0,0,0,0.2);">2</div>
          <span style="font-size: 12px; color: #94a3b8; font-weight: 500;">Transform</span>
        </div>
        
        <div class="etl-step" id="etlStep3" style="position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 10px; width: 60px;">
          <div class="etl-circle" style="width: 32px; height: 32px; border-radius: 50%; background: #1e293b; border: 2px solid #334155; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; color: #94a3b8; transition: all 0.3s ease; box-shadow: 0 0 0 4px rgba(0,0,0,0.2);">3</div>
          <span style="font-size: 12px; color: #94a3b8; font-weight: 500;">Load</span>
        </div>
        
        <div class="etl-step" id="etlStep4" style="position: relative; z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 10px; width: 60px;">
          <div class="etl-circle" style="width: 32px; height: 32px; border-radius: 50%; background: #1e293b; border: 2px solid #334155; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: bold; color: #94a3b8; transition: all 0.3s ease; box-shadow: 0 0 0 4px rgba(0,0,0,0.2);">✓</div>
          <span style="font-size: 12px; color: #94a3b8; font-weight: 500;">Complete</span>
        </div>
      </div>
      
      <div style="background: rgba(15, 23, 42, 0.5); padding: 12px 15px; border-radius: 6px; margin-top: 25px; border-left: 3px solid #3b82f6;">
        <p id="etlStatusText" style="margin: 0; color: #60a5fa; font-size: 14px; font-weight: 500; font-family: monospace;">> Initializing ETL Pipeline...</p>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('syncWarehouseBtn');
  const container = document.getElementById('etlProgressContainer');
  const bar = document.getElementById('etlProgressBar');
  const text = document.getElementById('etlStatusText');
  const steps = [
    document.getElementById('etlStep1'),
    document.getElementById('etlStep2'),
    document.getElementById('etlStep3'),
    document.getElementById('etlStep4')
  ];
  
  function updateStep(index, progress, message, active) {
    bar.style.width = progress + '%';
    text.textContent = '> ' + message;
    
    steps.forEach((step, i) => {
      const circle = step.querySelector('.etl-circle');
      const span = step.querySelector('span');
      
      // Reset animations
      circle.style.transform = 'scale(1)';
      
      if (i < index) {
        // completed
        circle.style.background = '#3b82f6';
        circle.style.borderColor = '#3b82f6';
        circle.style.color = 'white';
        span.style.color = 'white';
      } else if (i === index) {
        // active
        if (active) {
          circle.style.background = '#1e3a8a';
          circle.style.borderColor = '#3b82f6';
          circle.style.color = '#60a5fa';
          span.style.color = '#60a5fa';
          circle.style.transform = 'scale(1.15)';
        } else {
          // just completed
          circle.style.background = '#10b981'; // green for final completion
          circle.style.borderColor = '#10b981';
          circle.style.color = 'white';
          span.style.color = 'white';
          circle.style.transform = 'scale(1.15)';
          bar.style.background = '#10b981';
        }
      } else {
        // pending
        circle.style.background = '#1e293b';
        circle.style.borderColor = '#334155';
        circle.style.color = '#94a3b8';
        span.style.color = '#94a3b8';
      }
    });
  }

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    container.style.display = 'block';
    
    // Simulating the ETL process for visual feedback
    updateStep(0, 15, 'Extracting data from operational collections (Students, Marks, Attendance)...', true);
    
    setTimeout(() => {
      updateStep(1, 50, 'Transforming dimensions and aggregating facts...', true);
      
      setTimeout(async () => {
        updateStep(2, 80, 'Loading transformed data into data warehouse schema...', true);
        
        try {
          const response = await fetch('/reports/sync-warehouse', { method: 'POST' });
          if (response.ok) {
            updateStep(3, 100, 'ETL Process Completed Successfully! Reloading...', false);
            setTimeout(() => window.location.reload(), 1500);
          } else {
            text.textContent = '> ERROR: ETL Process Failed!';
            text.style.color = '#ef4444';
            btn.disabled = false;
          }
        } catch (error) {
          text.textContent = '> ERROR: Network Error during ETL Process!';
          text.style.color = '#ef4444';
          btn.disabled = false;
        }
      }, 1200);
    }, 1200);
  });
});
</script>

<section class="stat-grid">
  <article class="stat-card">
    <p>Fact Results</p>
    <h3><%= warehouseSummary.factResults %></h3>
  </article>
  <article class="stat-card">
    <p>Dim Students</p>
    <h3><%= warehouseSummary.dimStudents %></h3>
  </article>
  <article class="stat-card">
    <p>Dim Subjects</p>
    <h3><%= warehouseSummary.dimSubjects %></h3>
  </article>
  <article class="stat-card">
    <p>Dim Time</p>
    <h3><%= warehouseSummary.dimTime %></h3>
  </article>
  <article class="stat-card accent-card">
    <p>Dim Departments</p>
    <h3><%= warehouseSummary.dimDepartments %></h3>
  </article>
</section>

<section class="detail-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3>STAR Schema</h3>
    </div>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">
      The warehouse uses <strong>fact_results</strong> as the central fact table
      connecting to multiple dimension tables.
    </p>
    
    <div style="display: flex; align-items: center; justify-content: center; gap: 30px; padding: 30px; background: rgba(0,0,0,0.15); border-radius: 12px; margin-top: 15px; border: 1px solid rgba(255,255,255,0.05);">
      <div style="display: flex; flex-direction: column; gap: 20px;">
        <div style="padding: 12px 20px; background: #1e293b; border: 1px solid #3b82f6; border-radius: 8px; text-align: center; color: #93c5fd; font-weight: 500; box-shadow: 0 4px 6px rgba(0,0,0,0.2); position: relative;">
          dim_students
          <div style="position: absolute; right: -30px; top: 50%; width: 30px; height: 2px; background: #475569;"></div>
        </div>
        <div style="padding: 12px 20px; background: #1e293b; border: 1px solid #3b82f6; border-radius: 8px; text-align: center; color: #93c5fd; font-weight: 500; box-shadow: 0 4px 6px rgba(0,0,0,0.2); position: relative;">
          dim_subjects
          <div style="position: absolute; right: -30px; top: 50%; width: 30px; height: 2px; background: #475569;"></div>
        </div>
      </div>
      
      <div style="padding: 30px 40px; background: #0f172a; border: 2px solid #60a5fa; border-radius: 12px; text-align: center; font-weight: bold; font-size: 1.2em; color: white; box-shadow: 0 0 20px rgba(59, 130, 246, 0.3); z-index: 10;">
        fact_results<br><small style="font-weight: normal; color: #94a3b8; font-size: 0.75em; display: block; margin-top: 5px;">(Metrics & Keys)</small>
      </div>
      
      <div style="display: flex; flex-direction: column; gap: 20px;">
        <div style="padding: 12px 20px; background: #1e293b; border: 1px solid #3b82f6; border-radius: 8px; text-align: center; color: #93c5fd; font-weight: 500; box-shadow: 0 4px 6px rgba(0,0,0,0.2); position: relative;">
          <div style="position: absolute; left: -30px; top: 50%; width: 30px; height: 2px; background: #475569;"></div>
          dim_time
        </div>
        <div style="padding: 12px 20px; background: #1e293b; border: 1px solid #3b82f6; border-radius: 8px; text-align: center; color: #93c5fd; font-weight: 500; box-shadow: 0 4px 6px rgba(0,0,0,0.2); position: relative;">
          <div style="position: absolute; left: -30px; top: 50%; width: 30px; height: 2px; background: #475569;"></div>
          dim_departments
        </div>
      </div>
    </div>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Snowflake Schema</h3>
    </div>
    <p style="margin-bottom: 20px; color: var(--text-secondary);">
      The normalized design breaks dimensions further into hierarchies.
    </p>
    
    <div style="display: flex; flex-direction: column; gap: 25px; padding: 30px; background: rgba(0,0,0,0.15); border-radius: 12px; margin-top: 15px; align-items: center; border: 1px solid rgba(255,255,255,0.05);">
      <div style="display: flex; align-items: center; gap: 15px; width: 100%; justify-content: center;">
        <div style="padding: 12px 20px; background: #1e293b; border-radius: 8px; color: #cbd5e1; font-weight: 500; border: 1px solid rgba(255,255,255,0.1);">Student</div>
        <div style="color: #475569; font-weight: bold;">━━━━▶</div>
        <div style="padding: 12px 20px; background: #0f172a; border-radius: 8px; color: #93c5fd; font-weight: 500; border: 1px solid #3b82f6;">City</div>
        <div style="color: #475569; font-weight: bold;">━━━━▶</div>
        <div style="padding: 12px 20px; background: #1e3a8a; border-radius: 8px; color: white; font-weight: 500; border: 1px solid #60a5fa; box-shadow: 0 0 10px rgba(59, 130, 246, 0.4);">State</div>
      </div>
      
      <div style="width: 80%; height: 1px; background: rgba(255,255,255,0.05);"></div>
      
      <div style="display: flex; align-items: center; gap: 15px; width: 100%; justify-content: center;">
        <div style="padding: 12px 20px; background: #1e293b; border-radius: 8px; color: #cbd5e1; font-weight: 500; border: 1px solid rgba(255,255,255,0.1);">Subject</div>
        <div style="color: #475569; font-weight: bold;">━━━━▶</div>
        <div style="padding: 12px 20px; background: #0f172a; border-radius: 8px; color: #93c5fd; font-weight: 500; border: 1px solid #3b82f6;">Department</div>
        <div style="color: #475569; font-weight: bold;">━━━━▶</div>
        <div style="padding: 12px 20px; background: #1e3a8a; border-radius: 8px; color: white; font-weight: 500; border: 1px solid #60a5fa; box-shadow: 0 0 10px rgba(59, 130, 246, 0.4);">Course</div>
      </div>
    </div>
  </article>
</section>

<section class="detail-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3>Top 10 Students</h3>
    </div>
    <div class="table-wrap">
      <table class="data-table compact-table">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Name</th>
            <th>Department</th>
            <th>Average Marks</th>
          </tr>
        </thead>
        <tbody>
          <% reports.topTenStudents.forEach((student, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= student.fullName %></td>
              <td><%= student.department %></td>
              <td><%= student.averageMarks.toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Department Toppers</h3>
    </div>
    <div class="table-wrap">
      <table class="data-table compact-table">
        <thead>
          <tr>
            <th>Department</th>
            <th>Student</th>
            <th>Roll No</th>
            <th>Highest Marks</th>
          </tr>
        </thead>
        <tbody>
          <% reports.departmentToppers.forEach((item) => { %>
            <tr>
              <td><%= item._id %></td>
              <td><%= item.studentName %></td>
              <td><%= item.rollNumber %></td>
              <td><%= item.highestMarks %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
</section>

<section class="detail-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3>Failed Students by Subject</h3>
    </div>
    <div class="report-list">
      <% if (!reports.failedStudentsBySubject.length) { %>
        <p>No failed students found.</p>
      <% } %>
      <% reports.failedStudentsBySubject.forEach((subject) => { %>
        <div class="report-card">
          <h4><%= subject._id %> (<%= subject.failCount %>)</h4>
          <p>
            <% subject.students.forEach((student, index) => { %>
              <%= student.studentName %> - <%= student.rollNumber %> - <%= student.marks %><%= index !== subject.students.length - 1 ? ', ' : '' %>
            <% }) %>
          </p>
        </div>
      <% }) %>
    </div>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Low Attendance Students (&lt; 75%)</h3>
    </div>
    <div class="table-wrap">
      <table class="data-table compact-table">
        <thead>
          <tr>
            <th>Roll No</th>
            <th>Student</th>
            <th>Subject</th>
            <th>Attendance %</th>
          </tr>
        </thead>
        <tbody>
          <% if (!reports.lowAttendanceStudents.length) { %>
            <tr><td colspan="4" class="empty-state">No low attendance records found.</td></tr>
          <% } %>
          <% reports.lowAttendanceStudents.forEach((item) => { %>
            <tr>
              <td><%= item.rollNumber %></td>
              <td><%= item.studentName %></td>
              <td><%= item.subjectName %></td>
              <td><%= item.attendancePercentage %>%</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
</section>

<section class="detail-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3>Average Marks by Subject</h3>
    </div>
    <div class="table-wrap">
      <table class="data-table compact-table">
        <thead>
          <tr>
            <th>Subject</th>
            <th>Average Marks</th>
          </tr>
        </thead>
        <tbody>
          <% reports.averageMarksBySubject.forEach((item) => { %>
            <tr>
              <td><%= item._id %></td>
              <td><%= item.averageMarks.toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Semester Wise Results</h3>
    </div>
    <div class="table-wrap">
      <table class="data-table compact-table">
        <thead>
          <tr>
            <th>Semester</th>
            <th>Total Students</th>
            <th>Pass Count</th>
            <th>Fail Count</th>
            <th>Average CGPA</th>
          </tr>
        </thead>
        <tbody>
          <% reports.semesterWiseResults.forEach((item) => { %>
            <tr>
              <td><%= item._id %></td>
              <td><%= item.totalStudents %></td>
              <td><%= item.passCount %></td>
              <td><%= item.failCount %></td>
              <td><%= item.averageCgpa.toFixed(2) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>
</section>

<%- include('../partials/shell-end') %>
