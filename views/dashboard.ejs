<%- include('partials/head', { pageTitle }) %>
<%- include('partials/shell-start', { pageTitle }) %>

<section class="hero-panel">
  <div>
    <span class="eyebrow">Overview</span>
    <h3>Welcome to the academic analytics dashboard</h3>
    <p>
      Track student records, semester outcomes, attendance, and performance
      trends from one place.
    </p>
  </div>
  <div class="hero-actions">
    <a class="btn btn-primary" href="/students/new">Add Student</a>
    <a class="btn btn-secondary" href="/reports">View Reports</a>
  </div>
</section>

<section class="stat-grid">
  <article class="stat-card">
    <p>Total Students</p>
    <h3><%= summary.totalStudents %></h3>
  </article>
  <article class="stat-card">
    <p>Total Subjects</p>
    <h3><%= summary.totalSubjects %></h3>
  </article>
  <article class="stat-card">
    <p>Passed Students</p>
    <h3><%= summary.passedStudents %></h3>
  </article>
  <article class="stat-card">
    <p>Failed Students</p>
    <h3><%= summary.failedStudents %></h3>
  </article>
  <article class="stat-card accent-card">
    <p>Average Attendance</p>
    <h3><%= summary.averageAttendance %>%</h3>
  </article>
</section>

<section class="chart-grid">
  <article class="panel">
    <div class="panel-heading">
      <h3>Top Students by Marks</h3>
    </div>
    <canvas id="topStudentsChart"></canvas>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Subject-wise Pass/Fail</h3>
    </div>
    <canvas id="subjectPassFailChart"></canvas>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Attendance vs Marks</h3>
    </div>
    <canvas id="attendanceMarksChart"></canvas>
  </article>

  <article class="panel">
    <div class="panel-heading">
      <h3>Department Performance</h3>
    </div>
    <canvas id="departmentPerformanceChart"></canvas>
  </article>

  <article class="panel panel-wide">
    <div class="panel-heading">
      <h3>Semester Result Analysis</h3>
    </div>
    <canvas id="semesterResultChart"></canvas>
  </article>
</section>

<script>
  window.dashboardData = <%- JSON.stringify(charts) %>;
</script>

<!-- ── At-Risk Students Widget ────────────────────────────────────────────── -->
<section class="panel" id="atRiskWidget" style="display:none">
  <div class="panel-heading">
    <div>
      <h3>⚠ At-Risk Students</h3>
      <p>Students flagged for low attendance or marks based on current thresholds.</p>
    </div>
    <a href="/at-risk" class="btn btn-small btn-secondary">View All →</a>
  </div>

  <div id="atRiskBadges" style="display:flex;gap:10px;margin-bottom:18px;flex-wrap:wrap"></div>

  <div id="atRiskList"></div>
</section>

<script>
(function () {
  fetch('/at-risk/data')
    .then((r) => r.json())
    .then((data) => {
      const widget = document.getElementById('atRiskWidget');
      const badges = document.getElementById('atRiskBadges');
      const list   = document.getElementById('atRiskList');

      if (!data.critical && !data.warning) return; // nothing to show
      widget.style.display = '';

      badges.innerHTML =
        (data.critical ? `<span class="atrisk-badge atrisk-critical">🔴 ${data.critical} Critical</span>` : '') +
        (data.warning  ? `<span class="atrisk-badge atrisk-warning">🟡 ${data.warning} Warning</span>`  : '');

      if (!data.students || !data.students.length) {
        list.innerHTML = '<p style="color:var(--text-soft)">No at-risk students found.</p>';
        return;
      }

      list.innerHTML = data.students.map((s) => `
        <div class="atrisk-row ${s.riskLevel === 'critical' ? 'atrisk-row-critical' : 'atrisk-row-warning'}">
          <div class="atrisk-student-info">
            <strong>${s.fullName}</strong>
            <span style="color:var(--text-soft);font-size:.87rem">${s.rollNumber} · ${s.department}</span>
          </div>
          <div class="atrisk-pills">
            ${s.issues.slice(0, 2).map((issue) => `<span class="atrisk-pill">${issue}</span>`).join('')}
            ${s.issues.length > 2 ? `<span class="atrisk-pill atrisk-pill-more">+${s.issues.length - 2} more</span>` : ''}
          </div>
        </div>
      `).join('');
    })
    .catch(() => {}); // non-critical — fail silently
})();
</script>

<%- include('partials/shell-end') %>
