<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/shell-start', { pageTitle }) %>

<section class="page-toolbar">
  <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
    <form class="search-form" method="GET" action="/student-profiles">
      <input
        type="text"
        name="search"
        placeholder="Search by roll number or name..."
        value="<%= search %>"
      />
      <button type="submit" class="btn btn-secondary">Search</button>
    </form>
  </div>
</section>

<section class="profile-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; padding-top: 20px;">
  <% if (students && students.length > 0) { %>
    <% students.forEach(student => { %>
      <a href="/student-profiles/<%= student._id %>" style="text-decoration: none; color: inherit;">
        <article class="panel" style="display: flex; flex-direction: column; align-items: center; padding: 25px; transition: transform 0.2s, box-shadow 0.2s; cursor: pointer;">
          <img src="/images/default-avatar.svg" alt="Student Image" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; margin-bottom: 15px; border: 3px solid var(--border-color, #eee);">
          <h3 style="margin-bottom: 5px; text-align: center; color: var(--text-color, #333);"><%= student.fullName %></h3>
          <span class="badge" style="margin-bottom: 15px; font-size: 0.85em;"><%= student.rollNumber %></span>
          
          <div style="width: 100%; display: flex; flex-direction: column; gap: 4px; font-size: 0.9em;">
            <p style="color: var(--text-soft, #555); margin: 0; display: flex; justify-content: space-between;">
              <span>Branch:</span> <strong><%= student.department %></strong>
            </p>
            <p style="color: var(--text-soft, #555); margin: 0; display: flex; justify-content: space-between;">
              <span>Course:</span> <strong><%= student.course %> (Sem <%= student.semester %>)</strong>
            </p>
            <p style="color: var(--text-soft, #555); margin: 0; display: flex; justify-content: space-between;">
              <span>Email:</span> 
              <strong style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 120px;" title="<%= student.email %>">
                <%= student.email %>
              </strong>
            </p>
          </div>
        </article>
      </a>
    <% }) %>
  <% } else { %>
    <p>No students found matching your criteria.</p>
  <% } %>
</section>

<style>
  .profile-grid article:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    border-color: var(--primary-color, #4361ee);
  }
</style>

<%- include('../partials/shell-end') %>
