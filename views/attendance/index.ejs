<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/shell-start', { pageTitle }) %>

<section class="page-toolbar" style="flex-direction: column; align-items: stretch; gap: 15px;">
  <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
    <form class="search-form" method="GET" action="/attendance" style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap;">
            <input type="hidden" name="semester" value="<%= typeof semester !== 'undefined' ? semester : '' %>" />
      
      <input
        type="text"
        name="search"
        placeholder="Search by roll number, student name, subject"
        value="<%= search %>"
      />
      <button type="submit" class="btn btn-secondary">Search</button>
    </form>

    <div style="display:flex;gap:10px;flex-wrap:wrap;">
      <button id="openAttendanceUpload" class="btn btn-secondary">⬆ Upload CSV / Excel</button>
      <a class="btn btn-secondary" href="/attendance/export?search=<%= search %>">⬇ Download Template</a>
      <a class="btn btn-primary" href="/attendance/new">Add Attendance</a>
    </div>
  </div>

  <div class="filter-groups" style="display: flex; gap: 20px; flex-wrap: wrap;">
    <div class="subject-filters" style="display:flex;gap:10px;flex-wrap:wrap;">
      <button onclick="updateGlobalSubject('')" class="btn <%= !locals.globalSubject ? 'btn-primary' : 'btn-secondary' %>">All Subjects</button>
      <% if (locals.filterSubjects && locals.filterSubjects.length > 0) { %>
        <% filterSubjects.forEach(sub => { %>
          <button onclick="updateGlobalSubject('<%= sub._id %>')" class="btn <%= locals.globalSubject === sub._id.toString() ? 'btn-primary' : 'btn-secondary' %>"><%= sub.subjectName %></button>
        <% }) %>
      <% } %>
    </div>
  </div>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h3>Attendance Records</h3>
      <p>Attendance percentage is calculated automatically.</p>
    </div>
  </div>

  <div class="table-wrap">
    <table class="data-table" data-live-filter>
      <thead>
        <tr>
          <th>Roll No</th>
          <th>Student</th>
          <th>Subject</th>
          <th>Total Classes</th>
          <th>Present</th>
          <th>Attendance %</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!attendanceRecords.length) { %>
          <tr><td colspan="7" class="empty-state">No attendance records found.</td></tr>
        <% } %>
        <% attendanceRecords.forEach((record) => { %>
          <tr>
            <td><%= record.rollNumber %></td>
            <td><%= record.studentName %></td>
            <td><%= record.subjectName %></td>
            <td><%= record.totalClasses %></td>
            <td><%= record.presentClasses %></td>
            <td><%= record.attendancePercentage %>%</td>
            <td class="actions">
              <a class="btn btn-small btn-secondary" href="/attendance/<%= record._id %>/edit">Edit</a>
              <form action="/attendance/<%= record._id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-small btn-danger" data-confirm="Delete this attendance record?">
                  Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<!-- ── Upload Modal ──────────────────────────────────────────────── -->
<div class="modal" id="attendanceUploadModal" role="dialog" aria-modal="true" aria-labelledby="attendanceUploadTitle">
  <div class="modal-card">
    <div class="modal-header">
      <h3 id="attendanceUploadTitle">Bulk Upload Attendance</h3>
      <button class="modal-close" id="closeAttendanceUpload" aria-label="Close">✕</button>
    </div>

    <a class="upload-template-link" href="/attendance/export" download>
      ⬇ Download CSV template (pre-filled with student data)
    </a>

    <div style="padding:0 20px;margin-bottom:10px;">
      <p style="font-size:13px;color:var(--text-secondary);margin:0;">CSV columns: <strong>Roll No, Student Name, Subject, Total Classes, Present, Internal, External</strong>.<br/>This upload updates <em>both</em> Attendance and Marks simultaneously.</p>
    </div>

    <div class="upload-zone" id="attendanceDropZone">
      <span class="upload-zone-icon">📂</span>
      <p><strong>Click to browse</strong> or drag & drop your file here</p>
      <p>Accepted formats: .csv, .xlsx &nbsp;·&nbsp; Max 5 MB</p>
      <input type="file" id="attendanceFileInput" accept=".csv,.xlsx" />
    </div>

    <div class="file-chip" id="attendanceFileChip">
      <span id="attendanceFileName"></span>
      <button type="button" id="attendanceClearFile" aria-label="Remove file">✕</button>
    </div>

    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
      <button class="btn btn-primary" id="attendanceUploadBtn" disabled>Upload</button>
      <div class="upload-spinner" id="attendanceSpinner">
        <div class="spinner-ring"></div>
        <span>Uploading…</span>
      </div>
    </div>

    <div class="upload-result" id="attendanceResult">
      <div class="upload-summary" id="attendanceSummary"></div>
      <button class="upload-errors-toggle" id="attendanceErrorsToggle">▶ Show failed rows</button>
      <div class="upload-errors-table-wrap" id="attendanceErrorsWrap">
        <table class="upload-errors-table">
          <thead><tr><th>#</th><th>Identifier</th><th>Reason</th></tr></thead>
          <tbody id="attendanceErrorsBody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const modal      = document.getElementById('attendanceUploadModal');
  const openBtn    = document.getElementById('openAttendanceUpload');
  const closeBtn   = document.getElementById('closeAttendanceUpload');
  const dropZone   = document.getElementById('attendanceDropZone');
  const fileInput  = document.getElementById('attendanceFileInput');
  const fileChip   = document.getElementById('attendanceFileChip');
  const fileName   = document.getElementById('attendanceFileName');
  const clearFile  = document.getElementById('attendanceClearFile');
  const uploadBtn  = document.getElementById('attendanceUploadBtn');
  const spinner    = document.getElementById('attendanceSpinner');
  const result     = document.getElementById('attendanceResult');
  const summary    = document.getElementById('attendanceSummary');
  const errToggle  = document.getElementById('attendanceErrorsToggle');
  const errWrap    = document.getElementById('attendanceErrorsWrap');
  const errBody    = document.getElementById('attendanceErrorsBody');
  let errVisible   = false;

  openBtn.addEventListener('click', () => { resetModal(); modal.classList.add('active'); });
  closeBtn.addEventListener('click', () => modal.classList.remove('active'));
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('active'); });

  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault(); dropZone.classList.remove('drag-over');
    if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files[0]) setFile(fileInput.files[0]); });
  clearFile.addEventListener('click', () => { fileInput.value = ''; fileChip.classList.remove('visible'); uploadBtn.disabled = true; });

  function setFile(f) {
    fileName.textContent = f.name;
    fileChip.classList.add('visible');
    uploadBtn.disabled = false;
    result.classList.remove('visible');
  }

  uploadBtn.addEventListener('click', async () => {
    if (!fileInput.files[0]) return;
    spinner.classList.add('visible');
    uploadBtn.disabled = true;
    result.classList.remove('visible');

    const fd = new FormData();
    fd.append('file', fileInput.files[0]);

    try {
      const res  = await fetch('/attendance/upload', { method: 'POST', body: fd });
      const data = await res.json();
      renderResult(data);
    } catch (e) {
      renderResult({ success: false, message: 'Network error. Please try again.' });
    } finally {
      spinner.classList.remove('visible');
    }
  });

  errToggle.addEventListener('click', () => {
    errVisible = !errVisible;
    errToggle.textContent = (errVisible ? '▼ Hide' : '▶ Show') + ' failed rows';
    errWrap.classList.toggle('visible', errVisible);
  });

  function renderResult(data) {
    result.classList.add('visible');
    if (!data.success) {
      summary.innerHTML = `<div class="upload-stat upload-stat-error">⚠ ${data.message}</div>`;
      errToggle.classList.remove('visible'); errWrap.classList.remove('visible');
      return;
    }
    summary.innerHTML =
      `<div class="upload-stat upload-stat-success">✓ ${data.successCount} records updated (Attendance & Marks)</div>` +
      (data.errorCount ? `<div class="upload-stat upload-stat-error">✕ ${data.errorCount} failed</div>` : '');

    if (data.errors && data.errors.length) {
      errBody.innerHTML = data.errors.map((e) =>
        `<tr><td>${e.row}</td><td>${e.identifier || '—'}</td><td class="upload-error-msg">${e.message}</td></tr>`
      ).join('');
      errToggle.classList.add('visible');
      errVisible = false; errWrap.classList.remove('visible');
      errToggle.textContent = '▶ Show failed rows';
    } else {
      errToggle.classList.remove('visible'); errWrap.classList.remove('visible');
    }
  }

  function resetModal() {
    fileInput.value = ''; fileChip.classList.remove('visible');
    uploadBtn.disabled = true; spinner.classList.remove('visible');
    result.classList.remove('visible'); errToggle.classList.remove('visible');
    errWrap.classList.remove('visible'); errVisible = false;
  }
})();
</script>

<%- include('../partials/shell-end') %>
