<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/shell-start', { pageTitle }) %>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h3><%= attendance._id ? 'Edit Attendance' : 'Add Attendance' %></h3>
      <p>Present classes cannot be greater than total classes.</p>
    </div>
    <div class="metric-preview">
      <span data-attendance-preview>Attendance: --%</span>
    </div>
  </div>

  <form action="<%= formAction %>" method="<%= formMethod %>" class="form-grid">
    <label>
      Student
      <select name="student" required>
        <option value="">Select student</option>
        <% students.forEach((studentItem) => { %>
          <option
            value="<%= studentItem._id %>"
            <%= String(attendance.student || '') === String(studentItem._id) ? 'selected' : '' %>
          >
            <%= studentItem.rollNumber %> - <%= studentItem.fullName %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      Subject
      <select name="subject" required>
        <option value="">Select subject</option>
        <% subjects.forEach((subjectItem) => { %>
          <option
            value="<%= subjectItem._id %>"
            <%= String(attendance.subject || '') === String(subjectItem._id) ? 'selected' : '' %>
          >
            <%= subjectItem.subjectCode %> - <%= subjectItem.subjectName %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      Total Classes
      <input
        type="number"
        name="totalClasses"
        min="1"
        value="<%= attendance.totalClasses || '' %>"
        data-attendance-input
        required
      />
    </label>

    <label>
      Present Classes
      <input
        type="number"
        name="presentClasses"
        min="0"
        value="<%= attendance.presentClasses || '' %>"
        data-attendance-input
        required
      />
    </label>

    <div class="form-actions form-span">
      <a href="/attendance" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">Save Attendance</button>
    </div>
  </form>
</section>

<%- include('../partials/shell-end') %>
