<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/shell-start', { pageTitle }) %>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h3><%= student._id ? 'Edit Student' : 'Add Student' %></h3>
      <p>Fill all required fields carefully before saving.</p>
    </div>
  </div>

  <form action="<%= formAction %>" method="<%= formMethod %>" class="form-grid">
    <label>
      Roll Number
      <input type="text" name="rollNumber" value="<%= student.rollNumber || '' %>" required />
    </label>

    <label>
      Full Name
      <input type="text" name="fullName" value="<%= student.fullName || '' %>" required />
    </label>

    <label>
      Gender
      <select name="gender" required>
        <option value="">Select gender</option>
        <% ['Male', 'Female', 'Other'].forEach((item) => { %>
          <option value="<%= item %>" <%= student.gender === item ? 'selected' : '' %>><%= item %></option>
        <% }) %>
      </select>
    </label>

    <label>
      Department
      <select name="department" required>
        <option value="">Select department</option>
        <% departments.forEach((department) => { %>
          <option value="<%= department.name %>" <%= student.department === department.name ? 'selected' : '' %>>
            <%= department.name %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      Course
      <select name="course" required>
        <option value="">Select course</option>
        <% courses.forEach((course) => { %>
          <option value="<%= course.name %>" <%= student.course === course.name ? 'selected' : '' %>>
            <%= course.name %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      City
      <select name="city" required>
        <option value="">Select city</option>
        <% cities.forEach((city) => { %>
          <option value="<%= city.name %>" <%= student.city === city.name ? 'selected' : '' %>>
            <%= city.name %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      State
      <select name="state" required>
        <option value="">Select state</option>
        <% states.forEach((state) => { %>
          <option value="<%= state.name %>" <%= student.state === state.name ? 'selected' : '' %>>
            <%= state.name %>
          </option>
        <% }) %>
      </select>
    </label>

    <label>
      Semester
      <input type="number" name="semester" min="1" max="8" value="<%= student.semester || '' %>" required />
    </label>

    <label>
      Email
      <input type="email" name="email" value="<%= student.email || '' %>" required />
    </label>

    <label>
      Phone
      <input type="text" name="phone" value="<%= student.phone || '' %>" pattern="\d+" required />
    </label>

    <div class="form-actions form-span">
      <a href="/students" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">Save Student</button>
    </div>
  </form>
</section>

<%- include('../partials/shell-end') %>
