<%- include('../partials/head', { pageTitle }) %>
<%- include('../partials/shell-start', { pageTitle }) %>

<section class="page-toolbar">
  <form class="search-form" method="GET" action="/students">
    <input
      type="text"
      name="search"
      placeholder="Search by roll number, name, department, course"
      value="<%= search %>"
    />
    <button type="submit" class="btn btn-secondary">Search</button>
  </form>

  <div style="display:flex;gap:10px;flex-wrap:wrap;">
    <button id="openStudentUpload" class="btn btn-secondary">⬆ Upload CSV / Excel</button>
    <a class="btn btn-primary" href="/students/new">Add Student</a>
  </div>
</section>

<section class="panel">
  <div class="panel-heading">
    <div>
      <h3>All Students</h3>
      <p><%= pagination.totalItems %> records found</p>
    </div>
  </div>

  <div class="table-wrap">
    <table class="data-table" data-live-filter>
      <thead>
        <tr>
          <th>Roll No</th>
          <th>Name</th>
          <th>Department</th>
          <th>Course</th>
          <th>Semester</th>
          <th>City</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!students.length) { %>
          <tr>
            <td colspan="7" class="empty-state">No students found.</td>
          </tr>
        <% } %>

        <% students.forEach((student) => { %>
          <tr>
            <td><%= student.rollNumber %></td>
            <td><%= student.fullName %></td>
            <td><%= student.department %></td>
            <td><%= student.course %></td>
            <td>Semester <%= student.semester %></td>
            <td><%= student.city %></td>
            <td class="actions">
              <a class="btn btn-small" href="/students/<%= student._id %>">View</a>
              <a class="btn btn-small btn-secondary" href="/students/<%= student._id %>/edit">Edit</a>
              <form action="/students/<%= student._id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-small btn-danger" data-confirm="Delete this student and related records?">
                  Delete
                </button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <%- include('../partials/pagination', { pagination, search }) %>
</section>

<!-- ── Upload Modal ──────────────────────────────────────────────── -->
<div class="modal" id="studentUploadModal" role="dialog" aria-modal="true" aria-labelledby="studentUploadTitle">
  <div class="modal-card">
    <div class="modal-header">
      <h3 id="studentUploadTitle">Bulk Upload Students</h3>
      <button class="modal-close" id="closeStudentUpload" aria-label="Close">✕</button>
    </div>

    <a class="upload-template-link" href="/templates/students_template.csv" download>
      ⬇ Download sample template (students_template.csv)
    </a>

    <div class="upload-zone" id="studentDropZone">
      <span class="upload-zone-icon">📂</span>
      <p><strong>Click to browse</strong> or drag & drop your file here</p>
      <p>Accepted formats: .csv, .xlsx &nbsp;·&nbsp; Max 5 MB</p>
      <input type="file" id="studentFileInput" accept=".csv,.xlsx" />
    </div>

    <div class="file-chip" id="studentFileChip">
      <span id="studentFileName"></span>
      <button type="button" id="studentClearFile" aria-label="Remove file">✕</button>
    </div>

    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
      <button class="btn btn-primary" id="studentUploadBtn" disabled>Upload</button>
      <div class="upload-spinner" id="studentSpinner">
        <div class="spinner-ring"></div>
        <span>Uploading…</span>
      </div>
    </div>

    <div class="upload-result" id="studentResult">
      <div class="upload-summary" id="studentSummary"></div>
      <button class="upload-errors-toggle" id="studentErrorsToggle">▶ Show failed rows</button>
      <div class="upload-errors-table-wrap" id="studentErrorsWrap">
        <table class="upload-errors-table">
          <thead><tr><th>#</th><th>Identifier</th><th>Reason</th></tr></thead>
          <tbody id="studentErrorsBody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const modal       = document.getElementById('studentUploadModal');
  const openBtn     = document.getElementById('openStudentUpload');
  const closeBtn    = document.getElementById('closeStudentUpload');
  const dropZone    = document.getElementById('studentDropZone');
  const fileInput   = document.getElementById('studentFileInput');
  const fileChip    = document.getElementById('studentFileChip');
  const fileName    = document.getElementById('studentFileName');
  const clearFile   = document.getElementById('studentClearFile');
  const uploadBtn   = document.getElementById('studentUploadBtn');
  const spinner     = document.getElementById('studentSpinner');
  const result      = document.getElementById('studentResult');
  const summary     = document.getElementById('studentSummary');
  const errToggle   = document.getElementById('studentErrorsToggle');
  const errWrap     = document.getElementById('studentErrorsWrap');
  const errBody     = document.getElementById('studentErrorsBody');
  let errVisible    = false;

  openBtn.addEventListener('click', () => { resetModal(); modal.classList.add('active'); });
  closeBtn.addEventListener('click', () => modal.classList.remove('active'));
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('active'); });

  dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('drag-over'); });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e) => {
    e.preventDefault(); dropZone.classList.remove('drag-over');
    if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', () => { if (fileInput.files[0]) setFile(fileInput.files[0]); });
  clearFile.addEventListener('click', () => { fileInput.value = ''; fileChip.classList.remove('visible'); uploadBtn.disabled = true; });

  function setFile(f) {
    fileName.textContent = f.name;
    fileChip.classList.add('visible');
    uploadBtn.disabled = false;
    result.classList.remove('visible');
  }

  uploadBtn.addEventListener('click', async () => {
    if (!fileInput.files[0]) return;
    spinner.classList.add('visible');
    uploadBtn.disabled = true;
    result.classList.remove('visible');

    const fd = new FormData();
    fd.append('file', fileInput.files[0]);

    try {
      const res  = await fetch('/students/upload', { method: 'POST', body: fd });
      const data = await res.json();
      renderResult(data);
    } catch (e) {
      renderResult({ success: false, message: 'Network error. Please try again.' });
    } finally {
      spinner.classList.remove('visible');
    }
  });

  errToggle.addEventListener('click', () => {
    errVisible = !errVisible;
    errToggle.textContent = (errVisible ? '▼ Hide' : '▶ Show') + ' failed rows';
    errWrap.classList.toggle('visible', errVisible);
  });

  function renderResult(data) {
    result.classList.add('visible');
    if (!data.success) {
      summary.innerHTML = `<div class="upload-stat upload-stat-error">⚠ ${data.message}</div>`;
      errToggle.classList.remove('visible'); errWrap.classList.remove('visible');
      return;
    }
    summary.innerHTML =
      `<div class="upload-stat upload-stat-success">✓ ${data.successCount} added successfully</div>` +
      (data.errorCount ? `<div class="upload-stat upload-stat-error">✕ ${data.errorCount} failed</div>` : '');

    if (data.errors && data.errors.length) {
      errBody.innerHTML = data.errors.map((e) =>
        `<tr><td>${e.row}</td><td>${e.identifier || '—'}</td><td class="upload-error-msg">${e.message}</td></tr>`
      ).join('');
      errToggle.classList.add('visible');
      errVisible = false; errWrap.classList.remove('visible');
      errToggle.textContent = '▶ Show failed rows';
    } else {
      errToggle.classList.remove('visible'); errWrap.classList.remove('visible');
    }
  }

  function resetModal() {
    fileInput.value = ''; fileChip.classList.remove('visible');
    uploadBtn.disabled = true; spinner.classList.remove('visible');
    result.classList.remove('visible'); errToggle.classList.remove('visible');
    errWrap.classList.remove('visible'); errVisible = false;
  }
})();
</script>

<%- include('../partials/shell-end') %>
