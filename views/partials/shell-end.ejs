      </main>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="/js/main.js"></script>

  <!-- At-risk sidebar badge (non-blocking) -->
  <script>
  (function () {
    const badge = document.getElementById('atRiskBadge');
    if (!badge) return;
    fetch('/at-risk/data')
      .then((r) => r.json())
      .then((data) => {
        if (data.critical > 0) {
          badge.textContent = data.critical;
          badge.style.display = 'inline-flex';
        }
      })
      .catch(() => {}); // silent fail — non-critical UI
  })();
  </script>
  <!-- Global Filters (Subject & Branch) moved to sidebar -->
  <script>
    function updateGlobalBranch(branch) {
      fetch('/set-global-branch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ branch })
      }).then(() => window.location.reload());
    }
    
    function updateGlobalSubject(subject) {
      fetch('/set-global-subject', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ subject })
      }).then(() => window.location.reload());
    }
  </script>
</body>
</html>
